        "reason": "Alpine/musl Arm32 is in the .NET portable RID graph and maps to SDL3 Linux, but needs a checked cross/container toolchain."
      },
      {
        "rid": "linux-arm",
        "reason": "Linux Arm32 is in the .NET portable RID graph and maps to SDL3 Linux, but needs a checked glibc Arm32 cross/container toolchain."
      },
      {
        "rid": "linux-ppc64le",
        "reason": ".NET 10 supported OS policy includes ppc64le on enterprise Linux and SDL3 maps it to Linux, but the release pipeline needs a checked cross/container toolchain and package restore proof."
      },
      {
        "rid": "linux-s390x",
        "reason": ".NET 10 supported OS policy includes s390x on enterprise Linux and SDL3 maps it to Linux, but the release pipeline needs a checked cross/container toolchain and endian/runtime dependency proof."
      },
      {
        "rid": "browser-wasm",
        "reason": ".NET browser WebAssembly and SDL3 Emscripten overlap, but packaging is separate from desktop-style runtimes/<rid>/native."
      }
    ],
    "candidateTier": [
      {
