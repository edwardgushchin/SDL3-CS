      {
        "rid": "linux-musl-x64",
        "reason": "Alpine/musl is in the .NET portable RID graph and maps to SDL3 Linux, but needs dedicated musl container jobs."
      },
      {
        "rid": "linux-musl-arm64",
        "reason": "Alpine/musl Arm64 is in the .NET portable RID graph and maps to SDL3 Linux, but needs dedicated musl Arm64 container jobs."
      },
