    "excludedPlatformFamilies": [
      {
        "family": "netbsd-qnx-riscos-dos-retro",
        "reason": "SDL3 lists NetBSD, QNX, RISC OS, DOS and retro/homebrew systems, but they do not have a public official .NET RID/TFM release surface for normal SDL3-CS NuGet packages."
      },
      {
        "family": "visionos",
        "reason": "SDL3 lists visionOS, but .NET has no public visionos RID/TFM in the current portable release surface."
      },
      {
        "family": "wasi-wasm",
        "reason": ".NET has wasi-wasm in the portable RID graph, but SDL3 does not list WASI as a supported platform."
      },
      {
        "family": "tizen",
        "reason": "Tizen is a Samsung .NET/MAUI surface, but SDL3 does not list Tizen as a supported platform."
      },
      {
        "family": "legacy-portable-rids",
        "reason": "The portable RID graph still contains legacy or graph-only RIDs such as ios-arm, ios-x86, iossimulator-x86, tvos-x64, linux-x86, linux-armel and linux-armv6; these are not part of the official .NET 10 supported OS release surface for SDL3-CS."
      },
      {
        "family": "consoles-gdk-homebrew-nda",
        "reason": "SDL3 has console, GDK, NDA-only and homebrew paths, but they require separate SDK/legal/release policy and are not ordinary public NuGet targets."
      },
      {
        "family": "legacy-unsupported",
        "reason": "SDL3 marks WinRT/UWP/WinPhone, NaCL, Stadia, OS/2 and Pandora as unsupported; SDL3-CS release packages do not target them."
      }
    ]
